# JOFLOW Environment Variables

# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Services (Optional - for enhanced AI features)
# Without these, JOFLOW will use local AI algorithms

# OpenAI GPT API (for advanced text analysis)
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_MODEL=gpt-3.5-turbo

# Google Cloud AI (for sentiment analysis & translation)
VITE_GOOGLE_AI_API_KEY=your_google_ai_api_key_here
VITE_GOOGLE_PROJECT_ID=your_google_project_id_here

# Hugging Face (for emotion detection)
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Map Configuration (Optional)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Development Settings
VITE_APP_ENV=development
VITE_DEBUG_MODE=true